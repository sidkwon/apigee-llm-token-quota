    <Source clearPayload="false">request</Source>
    <Header name="Authorization">
        <Pattern ignoreCase="false">Bearer {identity_token}</Pattern>
    </Header>
    <IgnoreUnresolvedVariables>false</IgnoreUnresolvedVariables>
</ExtractVariables>
