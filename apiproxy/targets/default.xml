<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="default">
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>JS-SetTargetUrl</Name>
      </Step>
      <Step>
        <Name>JS-AddBillingLabels</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <Flows/>
  <PostFlow name="PostFlow">
    <Request/>
    <Response>
      <Step>
        <Name>JS-ExtractClaudeTokens</Name>
        <Condition>response.header.Content-Type != "text/event-stream"</Condition>
      </Step>
      <Step>
        <Name>LTQ-TokenCount</Name>
        <Condition>(response.header.Content-Type != "text/event-stream") and (total_token_count != null) and (total_token_count > 0)</Condition>
      </Step>
      <Step>
        <Name>DC-CollectTokenCounts</Name>
        <Condition>response.header.Content-Type != "text/event-stream"</Condition>
      </Step>

    </Response>
  </PostFlow>
  <EventFlow content-type="text/event-stream">
    <Response>
      <Step>
        <Name>JS-ExtractEventTokens</Name>
      </Step>
      <Step>
        <Name>LTQ-TokenCount</Name>
        <Condition>is_final_usage_event = true</Condition>
      </Step>
      <Step>
        <Name>DC-CollectTokenCounts</Name>
        <Condition>is_final_usage_event = true</Condition>
      </Step>

    </Response>
  </EventFlow>
  <HTTPTargetConnection>
    <URL>https://aiplatform.googleapis.com</URL>
    <Properties>
      <Property name="connect.timeout.millis">60000</Property>
      <Property name="io.timeout.millis">300000</Property>
    </Properties>
  </HTTPTargetConnection>
</TargetEndpoint>
